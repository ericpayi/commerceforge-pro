    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.22.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.1",
    "react-window": "^2.2.7",
    "recharts": "^3.9.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "zod": "^4.4.3",
